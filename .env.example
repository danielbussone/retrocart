# Copy to .env at repo root: cp .env.example .env

# Postgres (host port 5434 when using docker compose)
DATABASE_URL=postgresql://retrocart:retrocart@localhost:5434/retrocart

# Dev-only seed user (must match db/sql/V4__dev_seed.sql)
DEV_USER_ID=00000000-0000-4000-8000-000000000001

# GraphQL API
PORT=4000
NODE_ENV=development

# Internal generator service (not wired in scaffold)
GENERATOR_URL=http://localhost:8001

# Expo / mobile (web and native dev clients)
EXPO_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
EXPO_PUBLIC_DEV_USER_ID=00000000-0000-4000-8000-000000000001
